#!/bin/bash

MODEL=ggml-large-v3.bin
#MODEL=ggml-tiny.bin
#MODEL=ggml-large-v3-turbo-q5_0.bin

FILE="$1"
BASEFILE="${file_name%.*}"
shift

ffmpeg -i "$FILE" -ar 16000 -ac 1 -c:a pcm_s16le "/tmp/$BASEFILE.wav"
whisper-cli -m ~/dev/whisper-cpp/$MODEL -f "/tmp/$BASEFILE.wav" -otxt -of "$BASEFILE.txt" -pc
rm "/tmp/$BASEFILE.wav"

